{
  "version": 2,
  "rewrites": [
    { "source": "/vault", "destination": "https://identite-api.onrender.com/vault" },
    { "source": "/vault/approve", "destination": "https://identite-api.onrender.com/vault/approve" },
    { "source": "/vault/deny", "destination": "https://identite-api.onrender.com/vault/deny" },
    { "source": "/api/:path*", "destination": "https://identite-api.onrender.com/api/:path*" },
    { "source": "/images/:path*", "destination": "https://identite-api.onrender.com/images/:path*" },
    { "source": "/uploads/:path*", "destination": "https://identite-api.onrender.com/uploads/:path*" },
    { "source": "/robots.txt", "destination": "https://identite-api.onrender.com/robots.txt" },
    { "source": "/sitemap.xml", "destination": "https://identite-api.onrender.com/sitemap.xml" },
    { "source": "/contact", "destination": "https://identite-api.onrender.com/contact.html" },
    { "source": "/vault.html", "destination": "https://identite-api.onrender.com/vault.html" },
    { "source": "/(.*)", "destination": "https://identite-api.onrender.com/" }
  ]
}
